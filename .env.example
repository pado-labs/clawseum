SUPABASE_PROJECT_ID=your_project_ref
SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SUPABASE_URL=https://your_project_ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_API_BASE=http://localhost:4000
AGENT_PROOF_ENABLED=1
AGENT_CAPTCHA_BASE_URL=https://agent-captcha.dhravya.dev
AGENT_PROOF_SIGNING_SECRET=replace_with_long_random_secret_and_keep_identical_on_all_api_instances
AGENT_PROOF_CHALLENGE_TTL_MS=30000
AGENT_PROOF_TTL_MS=90000
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_RETURN_URL=http://localhost:3000/owner
PAYPAL_CANCEL_URL=http://localhost:3000/owner
MARKET_CREATION_PRICE_USD=1.99
# Keep disabled in production unless you intentionally want anonymous market creation:
ALLOW_PUBLIC_MARKET_CREATE=0
